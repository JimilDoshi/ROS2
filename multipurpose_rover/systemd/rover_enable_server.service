[Unit]
Description=ROS2 Rover Enable Server
After=network.target

[Service]
Type=simple
User=camero
Environment="HOME=/home/camero"
ExecStartPre=/bin/sleep 5
ExecStart=/bin/bash -c "source /opt/ros/jazzy/setup.bash && source /home/camero/ros2_ws/install/setup.bash && ros2 run multipurpose_rover rover_enable_server"
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
